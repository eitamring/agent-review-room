{
  "name": "agent-review-room",
  "version": "0.1.0",
  "description": "Local-first desktop app for orchestrating LLM code reviewers",
  "author": "eitam",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently \"npm:build:main\" \"npm:build:preload\" && concurrently -k -n renderer,app \"npm:dev:renderer\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "dev:app": "wait-on tcp:5173 && electron .",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "package": "npm run build && electron-builder",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "node --test tests/*.test.mjs"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
